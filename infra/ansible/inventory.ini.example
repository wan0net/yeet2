[yeet2]
yeet2-01 ansible_host=10.42.10.101

[yeet2_workers]
# Keep 10.42.10.100 for Hermes; use the next blank fleet node when available.
# yeet2-worker-01 ansible_host=10.42.10.102

[yeet2:vars]
ansible_user=icd
yeet2_repo_url=https://github.com/OWNER/yeet2.git
yeet2_repo_version=main
yeet2_deploy_dir=/opt/yeet2
yeet2_compose_file=docker-compose.release.yml
yeet2_install_code_harnesses=false

[yeet2_workers:vars]
ansible_user=icd
yeet2_repo_url=https://github.com/OWNER/yeet2.git
yeet2_repo_version=main
yeet2_deploy_dir=/opt/yeet2
yeet2_compose_file=docker-compose.worker.yml
yeet2_api_base_url=http://10.42.10.101:3001
yeet2_executor_worker_endpoint=http://10.42.10.102:8021
yeet2_executor_mode=claude
yeet2_executor_worker_capabilities=git,claude,codex,implementer,tester,coder,qa,reviewer
