{
  "name": "yeet2",
  "private": true,
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:ts": "vitest run",
    "lint": "pnpm -r --if-present lint",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev:control": "pnpm --filter @yeet2/control dev",
    "dev:api": "pnpm --filter @yeet2/api dev",
    "dev:brain": "cd apps/brain && PYTHONPATH=src .venv/bin/python -m yeet2_brain",
    "dev:executor": "cd apps/executor && PYTHONPATH=src python3 -m yeet2_executor"
  },
  "devDependencies": {
    "vite": "^8.0.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.2"
  }
}
