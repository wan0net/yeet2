{
  "name": "yeet2",
  "private": true,
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:ts": "vitest run",
    "lint": "pnpm -r --if-present lint",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "dev:control": "pnpm --filter @yeet2/control dev",
    "dev:api": "pnpm --filter @yeet2/api dev",
    "dev:brain": "cd apps/brain && PYTHONPATH=src .venv/bin/python -m yeet2_brain",
    "dev:executor": "cd apps/executor && PYTHONPATH=src python3 -m yeet2_executor",
    "db:generate": "pnpm --filter @yeet2/db exec prisma generate",
    "db:migrate": "pnpm --filter @yeet2/db exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @yeet2/db exec prisma migrate deploy",
    "db:migrate:status": "pnpm --filter @yeet2/db exec prisma migrate status",
    "db:push": "pnpm --filter @yeet2/db exec prisma db push",
    "db:backup": "pg_dump \"$DATABASE_URL\" --no-owner --no-acl -F c -f \"yeet2-backup-$(date +%Y%m%d-%H%M%S).dump\" && echo 'Backup complete'",
    "db:restore": "pg_restore --no-owner --no-acl -d \"$DATABASE_URL\" \"$npm_config_file\""
  },
  "devDependencies": {
    "vite": "^8.0.5",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "lodash-es": "^4.18.0",
      "esbuild": "^0.25.0",
      "vite@<6.4.2": "^6.4.2"
    }
  }
}
