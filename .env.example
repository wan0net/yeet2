# Core
NODE_ENV=development
YEET2_HOST=0.0.0.0

# Control / API / Brain / Executor
CONTROL_PORT=3000
API_PORT=3001
BRAIN_PORT=3002
EXECUTOR_PORT=3003
YEET2_BRAIN_PLANNER_BACKEND=auto # auto/crewai use Brain; deterministic is explicit-only
YEET2_BRAIN_CREWAI_ENABLED=false
YEET2_BRAIN_CREWAI_MODEL=
YEET2_BRAIN_PLAN_TIMEOUT_MS=45000
CREWAI_STORAGE_DIR=
CREWAI_DISABLE_TELEMETRY=true
HOME=

# Executor / OpenHands / Repo registration
YEET2_EXECUTOR_BASE_DIR=/tmp/yeet2-executor
# Base directory for repoUrl-driven project registration clones
YEET2_PROJECTS_DIR=/tmp/yeet2-projects
YEET2_EXECUTOR_MODE=openhands
# Executor sandboxing: off keeps the direct host path; asrt wraps OpenHands with srt and a per-job config
YEET2_EXECUTOR_SANDBOX_MODE=off
# Sandbox launcher binary for sandbox mode
YEET2_EXECUTOR_SANDBOX_BIN=srt
# Optional JSON object file path merged into each per-job sandbox config
YEET2_EXECUTOR_SANDBOX_BASE_CONFIG=
# Optional extra args passed to the sandbox launcher before the wrapped command
YEET2_EXECUTOR_SANDBOX_EXTRA_ARGS=
# Optional comma-separated network allowlist merged into the generated sandbox config
YEET2_EXECUTOR_SANDBOX_NETWORK=
YEET2_OPENHANDS_COMMAND=
YEET2_OPENHANDS_EXTRA_ARGS=
YEET2_OPENHANDS_PYTHON=3.12
YEET2_OPENHANDS_PACKAGE=openhands
YEET2_OPENHANDS_BIN=openhands
YEET2_OPENHANDS_TIMEOUT_SECONDS=
YEET2_OPENHANDS_ALLOW_LOCAL_FALLBACK=false
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=yeet2
POSTGRES_PASSWORD=yeet2
POSTGRES_DB=yeet2
DATABASE_URL=postgresql://yeet2:yeet2@localhost:5432/yeet2?schema=public

# Queue / Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# GitHub-style integration placeholders
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_BASE_URL=https://github.com
