# Core
NODE_ENV=development
YEET2_HOST=0.0.0.0

# Control / API / Brain / Executor
CONTROL_PORT=3000
API_PORT=3001
BRAIN_PORT=3002
EXECUTOR_PORT=3003
YEET2_API_BASE_URL=http://localhost:3001
YEET2_BRAIN_BASE_URL=http://localhost:3002
YEET2_EXECUTOR_BASE_URL=http://localhost:3003
YEET2_EXECUTOR_API_BASE_URL=http://localhost:3001
# SvelteKit CSRF origin (required for form submissions in production)
YEET2_CONTROL_ORIGIN=http://localhost:3000
YEET2_BRAIN_PLANNER_BACKEND=auto # auto/crewai use Brain; deterministic is explicit-only
YEET2_BRAIN_CREWAI_ENABLED=false
YEET2_BRAIN_CREWAI_MODEL=
YEET2_BRAIN_PLAN_TIMEOUT_MS=120000
CREWAI_STORAGE_DIR=
CREWAI_DISABLE_TELEMETRY=true
HOME=

# Agent name theme for fun display names (default: mythology)
# Options: mythology, star-trek, star-wars, firefly, hitchhikers, dune, lotr, matrix,
#          doctor-who, expanse, foundation, red-dwarf, futurama, blade-runner, westworld,
#          the-office, it-crowd, silicon-valley, severance, default
YEET2_AGENT_NAME_THEME=mythology

# Autonomy loop
YEET2_AUTONOMY_LOOP_ENABLED=true
YEET2_AUTONOMY_LOOP_INTERVAL_MS=60000
YEET2_AUTONOMY_LOOP_ACTOR=autonomy-loop
# Stuck job recovery: jobs running/queued longer than this (ms) are force-failed. Default 3600000 (1 hour). Min 60000.
YEET2_STUCK_JOB_TIMEOUT_MS=3600000

# Executor / OpenHands / Repo registration
YEET2_EXECUTOR_BASE_DIR=/tmp/yeet2-executor
# Base directory for repoUrl-driven project registration clones
YEET2_PROJECTS_DIR=/tmp/yeet2-projects
YEET2_EXECUTOR_MODE=openhands
# Executor sandboxing: off keeps the direct host path; asrt wraps OpenHands with srt and a per-job config
YEET2_EXECUTOR_SANDBOX_MODE=off
# Sandbox launcher binary for sandbox mode
YEET2_EXECUTOR_SANDBOX_BIN=srt
# Optional JSON object file path merged into each per-job sandbox config
YEET2_EXECUTOR_SANDBOX_BASE_CONFIG=
# Optional extra args passed to the sandbox launcher before the wrapped command
YEET2_EXECUTOR_SANDBOX_EXTRA_ARGS=
# Optional comma-separated network allowlist merged into the generated sandbox config
YEET2_EXECUTOR_SANDBOX_NETWORK=
YEET2_OPENHANDS_COMMAND=
YEET2_OPENHANDS_EXTRA_ARGS=
YEET2_OPENHANDS_PYTHON=3.12
YEET2_OPENHANDS_PACKAGE=openhands
YEET2_OPENHANDS_BIN=openhands
YEET2_OPENHANDS_TIMEOUT_SECONDS=
YEET2_OPENHANDS_ALLOW_LOCAL_FALLBACK=false
# Worktree cleanup after job completion: on_success (default), always, never
YEET2_EXECUTOR_WORKTREE_CLEANUP=on_success
# Timeout for OpenHands runs in seconds (blank = no timeout, risky for production)
YEET2_OPENHANDS_TIMEOUT_SECONDS=1800

# Executor worker identity (stable values recommended for production)
YEET2_EXECUTOR_WORKER_ID=
YEET2_EXECUTOR_WORKER_NAME=
YEET2_EXECUTOR_WORKER_HOST=
YEET2_EXECUTOR_WORKER_ENDPOINT=
YEET2_EXECUTOR_WORKER_CAPABILITIES=local
YEET2_EXECUTOR_HEARTBEAT_INTERVAL_SECONDS=30

# Local worker seed (API creates a local worker entry on startup)
YEET2_LOCAL_WORKER_ENABLED=true

# GHCR image overrides (for docker-compose.release.yml)
# YEET2_NODE_IMAGE=ghcr.io/wan0net/yeet2-node:latest
# YEET2_BRAIN_IMAGE=ghcr.io/wan0net/yeet2-brain:latest
# YEET2_EXECUTOR_IMAGE=ghcr.io/wan0net/yeet2-executor:latest
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=yeet2
POSTGRES_PASSWORD=yeet2
POSTGRES_DB=yeet2
DATABASE_URL=postgresql://yeet2:yeet2@localhost:5432/yeet2?schema=public

# Queue / Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# API bearer token — protects write endpoints. Generate with: openssl rand -hex 32
# Leave blank to disable auth (fine for local dev, not recommended for production).
YEET2_API_BEARER_TOKEN=

# GitHub-style integration placeholders
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_BASE_URL=https://github.com
