generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConstitutionStatus {
  pending
  parsed
  stale
  failed
}

enum ConstitutionParseStatus {
  pending
  parsed
  stale
  failed
}

enum ProjectStatus {
  active
  paused
  archived
}

enum ProjectAutonomyMode {
  manual
  supervised
  autonomous
}

enum ProjectPullRequestMode {
  manual
  after_implementer
  after_reviewer
}

enum ProjectPullRequestDraftMode {
  draft
  ready
}

enum ProjectMergeApprovalMode {
  human_approval
  agent_signoff
  no_approval
}

enum ProjectBranchCleanupMode {
  manual
  after_merge
}

enum ProjectBranchCleanupState {
  pending
  deleted
  retained
  failed
}

enum WorkerStatus {
  online
  busy
  offline
}

enum ProjectRoleKey {
  planner
  architect
  implementer
  qa
  reviewer
  visual
}

enum MissionStatus {
  planned
  active
  complete
  blocked
}

enum TaskStatus {
  pending
  ready
  running
  complete
  failed
  blocked
}

enum JobStatus {
  queued
  running
  complete
  failed
  cancelled
}

enum BlockerStatus {
  open
  resolved
  dismissed
}

model Project {
  id                 String              @id @default(cuid())
  name               String
  repoUrl            String?             @map("repo_url")
  githubRepoOwner    String?             @map("github_repo_owner")
  githubRepoName     String?             @map("github_repo_name")
  githubRepoUrl      String?             @map("github_repo_url")
  defaultBranch      String              @default("main") @map("default_branch")
  localPath          String              @unique @map("local_path")
  autonomyMode       ProjectAutonomyMode @default(manual) @map("autonomy_mode")
  pullRequestMode    ProjectPullRequestMode @default(manual) @map("pull_request_mode")
  pullRequestDraftMode ProjectPullRequestDraftMode @default(draft) @map("pull_request_draft_mode")
  mergeApprovalMode  ProjectMergeApprovalMode @default(human_approval) @map("merge_approval_mode")
  branchCleanupMode  ProjectBranchCleanupMode @default(manual) @map("branch_cleanup_mode")
  lastAutonomyRunAt  DateTime?           @map("last_autonomy_run_at")
  lastAutonomyStatus String?             @map("last_autonomy_status")
  lastAutonomyMessage String?            @map("last_autonomy_message")
  lastAutonomyActor  String?             @map("last_autonomy_actor")
  nextAutonomyRunAt  DateTime?           @map("next_autonomy_run_at")
  constitutionStatus ConstitutionStatus  @default(pending) @map("constitution_status")
  status             ProjectStatus       @default(active)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  constitution      Constitution?
  roleDefinitions    ProjectRoleDefinition[]
  decisionLogs       DecisionLog[]
  missions           Mission[]

  @@map("projects")
}

model ProjectRoleDefinition {
  id          String       @id @default(cuid())
  projectId   String       @map("project_id")
  roleKey     ProjectRoleKey @map("role_key")
  label       String
  goal        String
  backstory   String
  model       String?      @map("model")
  enabled     Boolean      @default(true)
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@map("project_role_definitions")
}

model DecisionLog {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  missionId   String?  @map("mission_id")
  taskId      String?  @map("task_id")
  jobId       String?  @map("job_id")
  blockerId   String?  @map("blocker_id")
  kind        String
  actor       String
  summary     String
  detail      Json?    @map("detail")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mission     Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  blocker     Blocker? @relation(fields: [blockerId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("decision_logs")
}

model Constitution {
  id               String                  @id @default(cuid())
  projectId        String                  @unique @map("project_id")
  visionPath       String?                 @map("vision_path")
  specPath         String?                 @map("spec_path")
  roadmapPath      String?                 @map("roadmap_path")
  architecturePath String?                 @map("architecture_path")
  decisionsPath    String?                 @map("decisions_path")
  qualityBarPath   String?                 @map("quality_bar_path")
  parseStatus      ConstitutionParseStatus @default(pending) @map("parse_status")
  lastIndexedAt    DateTime?               @map("last_indexed_at")
  project          Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("constitutions")
}

model Mission {
  id          String        @id @default(cuid())
  projectId   String        @map("project_id")
  title       String
  objective   String
  status      MissionStatus @default(planned)
  createdBy   String?       @map("created_by")
  startedAt   DateTime?     @map("started_at")
  completedAt DateTime?     @map("completed_at")
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  decisionLogs DecisionLog[]

  @@map("missions")
}

model Task {
  id                 String     @id @default(cuid())
  missionId          String     @map("mission_id")
  title              String
  description        String
  agentRole          String     @map("agent_role")
  assignedRoleDefinitionId String? @map("assigned_role_definition_id")
  assignedRoleDefinitionLabel String? @map("assigned_role_definition_label")
  status             TaskStatus @default(pending)
  priority           Int        @default(0)
  acceptanceCriteria Json       @map("acceptance_criteria")
  attempts           Int        @default(0)
  blockerReason      String?    @map("blocker_reason")
  mission            Mission    @relation(fields: [missionId], references: [id], onDelete: Cascade)
  jobs               Job[]
  blockers           Blocker[]
  decisionLogs       DecisionLog[]

  @@map("tasks")
}

model Job {
  id               String    @id @default(cuid())
  taskId           String    @map("task_id")
  executorType     String    @map("executor_type")
  workerId         String?   @map("worker_id")
  workspacePath    String    @map("workspace_path")
  branchName       String    @map("branch_name")
  githubCompareUrl String?   @map("github_compare_url")
  githubPrNumber   Int?      @map("github_pr_number")
  githubPrUrl      String?   @map("github_pr_url")
  githubPrTitle    String?   @map("github_pr_title")
  githubPrState    String?   @map("github_pr_state")
  githubPrDraft    Boolean?  @map("github_pr_draft")
  githubPrMergedAt DateTime? @map("github_pr_merged_at")
  githubBranchCleanupState ProjectBranchCleanupState @default(pending) @map("github_branch_cleanup_state")
  githubBranchDeletedAt DateTime? @map("github_branch_deleted_at")
  status           JobStatus @default(queued)
  logPath          String?   @map("log_path")
  artifactSummary  String?   @map("artifact_summary")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  task             Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  decisionLogs     DecisionLog[]

  @@map("jobs")
}

model Worker {
  id               String       @id @default(cuid())
  name             String
  executorType     String       @map("executor_type")
  status           WorkerStatus  @default(online)
  capabilities     Json
  lastHeartbeatAt  DateTime?    @map("last_heartbeat_at")
  leaseExpiresAt   DateTime?    @map("lease_expires_at")
  currentJobId     String?      @map("current_job_id")
  host             String?
  endpoint         String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([name, executorType])
  @@map("workers")
}

model Blocker {
  id             String        @id @default(cuid())
  taskId         String        @map("task_id")
  title          String
  context        String
  options        Json
  recommendation String?
  status         BlockerStatus @default(open)
  githubIssueNumber Int?       @map("github_issue_number")
  githubIssueUrl String?       @map("github_issue_url")
  createdAt      DateTime      @default(now()) @map("created_at")
  resolvedAt     DateTime?     @map("resolved_at")
  task           Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  decisionLogs   DecisionLog[]

  @@map("blockers")
}
